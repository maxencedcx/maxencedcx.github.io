---
import ProjectDetails from '../../../page-components/projectDetails.astro';
import { projects } from '../../../content/projects';

export function getStaticPaths() {
    return projects.map((p) => ({
        params: { slug: p.slug },
        props: { project: p },
    }));
}

const { project } = Astro.props;
---

<ProjectDetails lang="fr" project={project} />